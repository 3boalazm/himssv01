# HLOS — Environment Variables Template
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git

# API
NEXT_PUBLIC_API_URL=https://api.hlos.sa
API_INTERNAL_URL=http://hlos-api:3001

# Auth
NEXTAUTH_SECRET=change_me_in_production
NEXTAUTH_URL=https://hlos.sa

# Analytics (Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Feature flags
NEXT_PUBLIC_ENABLE_ENTERPRISE=true
